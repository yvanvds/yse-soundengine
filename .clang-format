---
Language:        Cpp
BasedOnStyle:    LLVM

# Indentation — 2-space, spaces only, matching the committed engine/test code
IndentWidth:     2
TabWidth:        2
UseTab:          Never

# Column limit — keep lines readable without being too strict
ColumnLimit:     100

# Brace placement — K&R / attach (open brace on the same line)
BreakBeforeBraces: Attach

# Namespaces are indented (namespace YSE { namespace INTERNAL { ... })
NamespaceIndentation: All

# Constructor initializer lists — colon leads the continuation line
BreakConstructorInitializers: BeforeColon
ConstructorInitializerIndentWidth: 2
PackConstructorInitializers: NextLine

# Pointer/reference alignment — left-attached (int* p, int& r)
PointerAlignment: Left
ReferenceAlignment: Left

# Short forms — keep guard clauses (if (x) return;) on one line, as the code has
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: WithoutElse
AllowShortLoopsOnASingleLine: false
AllowShortBlocksOnASingleLine: Empty

# Trailing comments — keep a single space, don't column-align across lines.
# Alignment is also unstable (non-idempotent) after an inline `}`.
AlignTrailingComments:
  Kind: Never

# Include sorting — keep existing grouping, don't reorder across blocks
SortIncludes:    false
