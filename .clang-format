---
Language:        Cpp
BasedOnStyle:    LLVM

# Indentation — tabs, 4-wide, matching the existing demo/engine code
IndentWidth:     4
TabWidth:        4
UseTab:          Always

# Column limit — keep lines readable without being too strict
ColumnLimit:     100

# Brace placement — Allman (open brace on its own line), matching Demo*.cpp
BreakBeforeBraces: Allman

# Constructor initializer lists — one entry per line
ConstructorInitializerAllOnOneLineOrOnePerLine: true
BreakConstructorInitializersBeforeComma: true
ConstructorInitializerIndentWidth: 4

# Pointer/reference alignment — left-attached (int* p)
PointerAlignment: Left
ReferenceAlignment: Left

# Short forms — leave empty functions on one line; never collapse if/loops
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

# Include sorting — keep existing grouping, don't reorder across blocks
SortIncludes:    false
